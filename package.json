{
  "name": "nextCIDR",
  "version": "0.1.0",
  "private": true,
  "homepage": "./",
  "scripts": {
    "start": "vite",
    "generate:parser": "peggy --format es -o ./src/parser/subnetsParser.js ./src/parser/subnets.pegjs",
    "prebuild": "npm run generate:parser",
    "pretest": "npm run generate:parser",
    "build": "vite build",
    "test": "vitest run --passWithNoTests",
    "eject": "vite eject",
    "serve": "vite previow",
    "deploy": "gh-pages -d dist"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "peggy": "^5.1.0",
    "react": "^19.2.5",
    "react-bootstrap": "^2.10.10"
  }
}
